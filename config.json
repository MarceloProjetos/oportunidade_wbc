{
  "sap": {
    "host": "${SAP_HOST}",
    "port": 30013,
    "user": "${SAP_USER}",
    "password": "${SAP_PASSWORD}",
    "database": "${SAP_DATABASE}",
    "charset": "UTF8",
    "timeout": 30
  },
  "supabase": {
    "url": "${SUPABASE_URL}",
    "key": "${SUPABASE_KEY}",
    "table_name": "oportunidades"
  },
  "extract": {
    "mode": "insert",
    "description": "Modos: insert (novos registros) ou upsert (atualiza existentes)",
    "batch_size": 100,
    "description_batch": "Quantidade de registros por lote"
  },
  "logging": {
    "level": "INFO",
    "file": "logs/extraction.log",
    "format": "%(asctime)s - %(name)s - %(levelname)s - %(message)s"
  }
}
