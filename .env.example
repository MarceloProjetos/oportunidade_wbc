# Configuração SAP HANA
SAP_HOST=seu_host_sap
SAP_PORT=30015
SAP_USER=seu_usuario_sap
SAP_PASSWORD=sua_senha_sap
SAP_DATABASE=SUA_DATABASE          # opcional: deixe em branco se o HANA conectar sem databaseName
SAP_SCHEMA=SBOALTAMIRAPROD         # schema onde a view está (ex.: SBOALTAMIRAPROD)
SAP_VIEW_NAME=VW_EVOL_OPORTUNIDADE_ALT

# Configuração Supabase
SUPABASE_URL=https://seu_project.supabase.co
SUPABASE_KEY=sua_chave_anon_publica
SUPABASE_SERVICE_ROLE_KEY=sua_chave_service_role   # usada na ESCRITA (ignora RLS)

# Tabela Supabase
TABLE_NAME=oportunidades
# SUPABASE_TIMEOUT_S=120           # opcional: timeout REST PostgREST em segundos (default: 120)

# Ordens de Serviço — pipeline sob demanda, por N_PED, espelhando a view HANA
# CONSOLIDADA VW_OS_INTEGRACAO (OS + estrutura/árvore + orçamento) numa ÚNICA tabela.
# (todas opcionais; têm default). Usa a MESMA conexão SAP acima.
# OS_SAP_VIEW_NAME=VW_OS_INTEGRACAO
# OS_TABLE_NAME=vw_os_integracao
# OS_SYNC_LOG_TABLE_NAME=sincronizacao_log_os_integracao
# OS_EXECUTION_MODE=replace_nped   # replace_nped (substitui o pedido) | insert (acumula)
# OS_INSERT_BATCH_SIZE=500         # lote de inserção
# --- API HTTP de disparo (api.py) ---
# OS_API_KEY=                      # chave do endpoint (RECOMENDADO em produção; vazio = sem auth)
# OS_API_HOST=0.0.0.0              # host do servidor da API
# OS_API_PORT=8077                 # porta do servidor da API

# Monitor da tarefa agendada "Integração WBC" (Task Scheduler do Windows)
# O script monitor_wbc_task.ps1 (agendado a cada 10 min via install_monitor_task.ps1)
# grava o estado; a API só LÊ o arquivo e o expõe em /status (?checks=tarefa).
# WBC_TASK_NAME=Integração WBC          # nome exato da tarefa monitorada no Task Scheduler
# WBC_TASK_STATE_FILE=state/wbc_task_state.json  # relativo à raiz do projeto (ou caminho absoluto)
# WBC_TASK_STALE_MIN=25                 # estado mais velho que isso = monitor possivelmente parado

# Windows Update / reboot pendente (windows_update.py — check `windows_update` do /status).
# A busca de updates custa ~3,1s nesta maquina (30s a frio) e roda numa THREAD daemon no
# start da API; o /status so le o cache. Nao ha agendador: o boot diario (~06:12) e o
# agendamento. Os defaults sao os medidos — so mexa com motivo.
# WU_ENABLED=true                       # false desliga a coleta (o reboot pendente continua)
# WU_DELAY_START_S=300                  # espera da thread apos o start da API
# WU_VARREDURA_MAX_D=7                  # varredura mais velha que isso => "pendentes" vira null
#                                       # (NUNCA 0: com o agente sem varrer a busca responde 0 e mente)
# WU_COLETA_TIMEOUT_S=120               # teto do powershell da coleta

# Configuração SQL Server (opcional — enriquece SITCOD/ORCALTDTH)
SQL_HOST=seu_host_sql
SQL_PORT=1433
SQL_USER=seu_usuario_sql
SQL_PASSWORD=sua_senha_sql
SQL_DATABASE=WBCCAD
# SQL_ENRICHMENT_VIEW=WBCCAD.dbo.INTEGRACAO_ORCSIT   # SQL Server view for SITCOD/ORCALTDTH
# SITCOD_DOMAIN_TABLE=situacoes_orcamento            # Supabase FK domain for SITCOD validation
# SQL_DRIVER=ODBC Driver 18 for SQL Server   # optional: force a specific ODBC driver
# Aliases: SQLSERVER_HOST, SQLSERVER_PORT, etc. (same as SQL_*)
# Obs.: o SQL Server segue em uso só pelo pipeline de OPORTUNIDADES; a árvore de
# produto WBC agora vem dentro da view HANA VW_OS_INTEGRACAO (não há mais sub-sync
# de árvore WBC via SQL Server nem de views de impressão).

# Scheduler (scripts/scheduled_execution.py)
# INTERVALO_MINUTOS=30
# JANELA_HORAS=7-18
# EXECUTION_MODE=snapshot          # snapshot | insert (upsert removido)
# Dias: seg-sex automático + feriados nacionais BR (feriados_br.py, até 2030)
